{
  "expo": {
    "name": "INVS MVP",
    "slug": "invs-mobile-mvp-fixed",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "INVS necesita acceso a la cámara para escanear códigos QR de eventos."
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "package": "com.invs.mobilemvp"
    },
    "plugins": [
      "expo-video"
    ]
  }
}
